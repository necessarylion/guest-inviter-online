# Node
TZ=UTC
PORT=3333
HOST=localhost
NODE_ENV=development

# App
LOG_LEVEL=info
APP_KEY=
APP_URL=http://${HOST}:${PORT}

# Admin: comma-separated list of user emails granted admin access
ADMIN_EMAILS=

# Session
SESSION_DRIVER=cookie

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_DATABASE=event_inviter

# Firebase Authentication (Google sign-in)
# Server (Admin SDK) — copy from the service account JSON you download from
# Firebase Console > Project settings > Service accounts > Generate new private key.
# Keep the private key on ONE line with literal \n for line breaks, wrapped in quotes.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
# Client (Web SDK) — from Firebase Console > Project settings > General > Your apps (Web app).
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_APP_ID=

# Mail (dev: MailHog/Mailpit SMTP catcher on localhost:1025)
MAIL_FROM_ADDRESS=no-reply@event-inviter.test
MAIL_FROM_NAME="Guest Invite"
SMTP_HOST=localhost
SMTP_PORT=1025
RESEND_API_KEY=
