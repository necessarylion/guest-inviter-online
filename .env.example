# Node
TZ=UTC
PORT=3333
HOST=localhost
NODE_ENV=development

# App
LOG_LEVEL=info
APP_KEY=
APP_URL=http://${HOST}:${PORT}

# Session
SESSION_DRIVER=cookie

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_DATABASE=event_inviter

# Mail (dev: MailHog/Mailpit SMTP catcher on localhost:1025)
MAIL_FROM_ADDRESS=no-reply@event-inviter.test
MAIL_FROM_NAME="Event Inviter"
SMTP_HOST=localhost
SMTP_PORT=1025
RESEND_API_KEY=
