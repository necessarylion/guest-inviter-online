# Copy to .env.production and fill in real values before deploying.
# Used by: docker compose -f docker-compose.prod.yml --env-file .env.production up -d --build

TZ=UTC
PORT=3333
LOG_LEVEL=info

# Generate with: node ace generate:key
APP_KEY=
APP_URL=https://your-domain.example

SESSION_DRIVER=cookie

# Number of clustered app instances PM2 should run (number or "max").
PM2_INSTANCES=1

# Database — DB_HOST/DB_PORT are fixed to the internal `postgres` service
# in docker-compose.prod.yml, so only credentials are set here.
DB_USER=postgres
DB_PASSWORD=change-me
DB_DATABASE=event_inviter
