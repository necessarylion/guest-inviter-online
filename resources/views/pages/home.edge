<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>Guest Invite — QR invitations & fast guest check-in</title>
    <meta
      name="description"
      content="Create events, build your guest list, and invite people by email, shareable link, or printable card. Every invitation carries a unique QR code for instant check-in at the door."
    />
    <link rel="canonical" href="{{ appUrl }}/" />
    <!--Open Graph-->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Guest Invite" />
    <meta property="og:title" content="Guest Invite — QR invitations & fast guest check-in" />
    <meta
      property="og:description"
      content="Invite guests by email, link, or printable card. Every invite has a unique QR code you scan at the door."
    />
    <meta property="og:url" content="{{ appUrl }}/" />
    <!--Twitter-->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Guest Invite — QR invitations & fast guest check-in" />
    <meta
      name="twitter:description"
      content="Invite guests by email, link, or printable card. Every invite has a unique QR code you scan at the door."
    />

    <script type="application/ld+json">






                                        {
                                          "@context": "https://schema.org",
                                          "@type": "SoftwareApplication",
                                          "name": "Guest Invite",
                                          "applicationCategory": "BusinessApplication",
                                          "operatingSystem": "Web",
                                          "description": "Create events, manage guest lists, and send QR-code invitations by email, link, or printable card with fast door check-in.",
                                          "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" }
                                        }






    </script>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&display=swap"
    />
    <link rel="stylesheet" href="https://unpkg.com/primeicons@7.0.0/primeicons.css" />

    <style>
      /* =========================================================
                                           PrimeVue Aura tokens — colors & typography (light scheme)
                                           ========================================================= */
      :root {
        --p-emerald-50: #ecfdf5;
        --p-emerald-100: #d1fae5;
        --p-emerald-200: #a7f3d0;
        --p-emerald-300: #6ee7b7;
        --p-emerald-400: #34d399;
        --p-emerald-500: #10b981;
        --p-emerald-600: #059669;
        --p-emerald-700: #047857;
        --p-emerald-800: #065f46;
        --p-emerald-900: #064e3b;
        --p-emerald-950: #022c22;

        --p-amber-500: #f59e0b;
        --p-sky-500: #0ea5e9;
        --p-violet-500: #8b5cf6;

        --p-slate-0: #ffffff;
        --p-slate-50: #f8fafc;
        --p-slate-100: #f1f5f9;
        --p-slate-200: #e2e8f0;
        --p-slate-300: #cbd5e1;
        --p-slate-400: #94a3b8;
        --p-slate-500: #64748b;
        --p-slate-600: #475569;
        --p-slate-700: #334155;
        --p-slate-800: #1e293b;
        --p-slate-900: #0f172a;
        --p-slate-950: #020617;

        --p-font-sans:
          'Inter', ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, Helvetica, Arial,
          sans-serif;
        --p-font-mono: 'JetBrains Mono', ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
      }

      /* =========================================================
                                           Landing tokens — Emerald accent, light scheme, layered
                                           ========================================================= */
      :root {
        --accent-50: var(--p-emerald-50);
        --accent-100: var(--p-emerald-100);
        --accent-400: var(--p-emerald-400);
        --accent-500: var(--p-emerald-500);
        --accent-600: var(--p-emerald-600);
        --accent-700: var(--p-emerald-700);
        --accent-contrast: #ffffff;

        --ink: var(--p-slate-900);
        --ink-2: var(--p-slate-600);
        --ink-3: var(--p-slate-500);
        --line: var(--p-slate-200);
        --bg: #ffffff;
        --bg-2: var(--p-slate-50);

        --radius: 16px;
        --radius-lg: 22px;
        --shadow-card: 0 1px 2px rgba(15, 23, 42, 0.04), 0 8px 24px -12px rgba(15, 23, 42, 0.12);
        --shadow-float:
          0 30px 60px -24px rgba(15, 23, 42, 0.3), 0 8px 20px -12px rgba(15, 23, 42, 0.18);
        --maxw: 1180px;
      }

      * {
        box-sizing: border-box;
      }
      html {
        scroll-behavior: smooth;
      }
      body {
        margin: 0;
        background: var(--bg);
        color: var(--ink);
        font-family: var(--p-font-sans);
        line-height: 1.5;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        overflow-x: hidden;
      }
      h1,
      h2,
      h3,
      h4,
      p {
        margin: 0;
      }

      .wrap {
        max-width: var(--maxw);
        margin: 0 auto;
        padding: 0 28px;
      }

      /* ---------- buttons ---------- */
      .btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 9px;
        font-family: inherit;
        font-size: 15px;
        font-weight: 600;
        padding: 13px 22px;
        border-radius: 12px;
        border: 1px solid transparent;
        cursor: pointer;
        text-decoration: none;
        white-space: nowrap;
        transition:
          transform 0.15s ease,
          background 0.2s,
          border-color 0.2s,
          box-shadow 0.2s,
          color 0.2s;
      }
      .btn:active {
        transform: translateY(1px);
      }
      .btn-primary {
        background: var(--accent-500);
        color: var(--accent-contrast);
        border-color: var(--accent-500);
        box-shadow: 0 8px 20px -8px color-mix(in srgb, var(--accent-500), transparent 45%);
      }
      .btn-primary:hover {
        background: var(--accent-600);
        border-color: var(--accent-600);
        color: var(--accent-contrast);
      }
      .btn-ghost {
        background: var(--bg);
        color: var(--ink);
        border-color: var(--line);
      }
      .btn-ghost:hover {
        background: var(--bg-2);
        border-color: var(--p-slate-300);
        color: var(--ink);
      }
      .btn-lg {
        padding: 16px 28px;
        font-size: 16px;
      }
      .btn-sm {
        padding: 9px 16px;
        font-size: 14px;
        border-radius: 10px;
      }

      /* ---------- nav ---------- */
      .nav {
        position: sticky;
        top: 0;
        z-index: 60;
        background: color-mix(in srgb, var(--bg), transparent 18%);
        backdrop-filter: saturate(140%) blur(12px);
        border-bottom: 1px solid transparent;
        transition:
          border-color 0.25s,
          background 0.25s;
      }
      .nav.scrolled {
        border-bottom-color: var(--line);
      }
      .nav .inner {
        max-width: var(--maxw);
        margin: 0 auto;
        padding: 16px 28px;
        display: flex;
        align-items: center;
        gap: 14px;
      }
      .brand {
        display: flex;
        align-items: center;
        gap: 11px;
        font-weight: 800;
        font-size: 19px;
        letter-spacing: -0.02em;
        color: var(--ink);
        text-decoration: none;
      }
      .brand .mark {
        width: 34px;
        height: 34px;
        border-radius: 10px;
        display: grid;
        place-items: center;
        background: var(--accent-500);
        color: var(--accent-contrast);
        font-size: 17px;
        box-shadow: 0 6px 16px -6px color-mix(in srgb, var(--accent-500), transparent 40%);
      }
      .nav .spacer {
        flex: 1;
      }
      .nav .navlink {
        color: var(--ink-2);
        font-size: 15px;
        font-weight: 500;
        text-decoration: none;
        padding: 8px 10px;
        border-radius: 8px;
      }
      .nav .navlink:hover {
        color: var(--ink);
      }

      /* ---------- hero ---------- */
      .hero {
        position: relative;
        padding: 86px 0 70px;
      }
      .hero .wrap {
        display: grid;
        grid-template-columns: 1.05fr 0.95fr;
        gap: 56px;
        align-items: center;
      }
      .glow {
        position: absolute;
        pointer-events: none;
        z-index: 0;
        width: 820px;
        height: 820px;
        left: 50%;
        top: -340px;
        transform: translateX(-46%);
        background: radial-gradient(
          closest-side,
          color-mix(in srgb, var(--accent-500), transparent 80%),
          transparent 72%
        );
        opacity: 1;
        transition: opacity 0.4s;
      }

      .eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        font-size: 13px;
        font-weight: 600;
        letter-spacing: 0.01em;
        color: var(--accent-700);
        background: var(--accent-50);
        border: 1px solid color-mix(in srgb, var(--accent-500), transparent 78%);
        padding: 7px 14px;
        border-radius: 999px;
        margin-bottom: 22px;
        white-space: nowrap;
      }
      .eyebrow .dot {
        width: 7px;
        height: 7px;
        border-radius: 50%;
        background: var(--accent-500);
      }

      h1.title {
        font-weight: 800;
        letter-spacing: -0.035em;
        line-height: 0.98;
        font-size: clamp(40px, 5.4vw, 68px);
        margin: 0 0 22px;
        color: var(--ink);
        text-wrap: balance;
      }
      h1.title .accent {
        color: var(--accent-500);
      }

      .lede {
        font-size: 19px;
        line-height: 1.55;
        color: var(--ink-2);
        max-width: 520px;
        margin: 0 0 30px;
        text-wrap: pretty;
      }
      .hero-cta {
        display: flex;
        gap: 13px;
        flex-wrap: wrap;
        align-items: center;
      }
      .hero-note {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-top: 20px;
        font-size: 14px;
        color: var(--ink-3);
      }
      .hero-note i {
        color: var(--accent-500);
      }

      /* ---------- phone scan demo ---------- */
      .hero-visual {
        position: relative;
        display: flex;
        justify-content: center;
        z-index: 1;
      }
      .stage {
        position: relative;
        width: 100%;
        max-width: 380px;
        display: flex;
        justify-content: center;
      }
      .phone {
        position: relative;
        width: 286px;
        height: 580px;
        border-radius: 46px;
        background: linear-gradient(160deg, #1f2937, #0b1220);
        padding: 13px;
        box-shadow: var(--shadow-float);
      }
      .phone::after {
        /* side button */
        content: '';
        position: absolute;
        right: -3px;
        top: 150px;
        width: 3px;
        height: 64px;
        border-radius: 3px;
        background: #243042;
      }
      .phone .notch {
        position: absolute;
        top: 22px;
        left: 50%;
        transform: translateX(-50%);
        width: 96px;
        height: 26px;
        background: #0b1220;
        border-radius: 14px;
        z-index: 5;
      }
      .screen {
        position: relative;
        width: 100%;
        height: 100%;
        border-radius: 34px;
        overflow: hidden;
        background: var(--bg);
        display: flex;
        flex-direction: column;
      }
      .scr-top {
        padding: 30px 20px 14px;
        display: flex;
        align-items: center;
        justify-content: space-between;
      }
      .scr-top .t {
        font-weight: 700;
        font-size: 15px;
        color: var(--ink);
      }
      .scr-top .live {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-size: 11px;
        font-weight: 600;
        color: var(--accent-700);
        background: var(--accent-50);
        padding: 4px 9px;
        border-radius: 999px;
      }
      .scr-top .live .blink {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: var(--accent-500);
        animation: blink 1.4s infinite;
      }
      @keyframes blink {
        0%,
        100% {
          opacity: 1;
        }
        50% {
          opacity: 0.25;
        }
      }

      .viewfinder {
        position: relative;
        margin: 6px 20px 0;
        aspect-ratio: 1;
        border-radius: 20px;
        background: linear-gradient(145deg, #0f172a, #1e293b);
        overflow: hidden;
        display: grid;
        place-items: center;
      }
      .viewfinder .vignette {
        position: absolute;
        inset: 0;
        background: radial-gradient(circle at 50% 40%, transparent 40%, rgba(0, 0, 0, 0.35));
      }
      .corner {
        position: absolute;
        width: 30px;
        height: 30px;
        border: 3px solid rgba(255, 255, 255, 0.85);
      }
      .corner.tl {
        top: 16px;
        left: 16px;
        border-right: 0;
        border-bottom: 0;
        border-radius: 8px 0 0 0;
      }
      .corner.tr {
        top: 16px;
        right: 16px;
        border-left: 0;
        border-bottom: 0;
        border-radius: 0 8px 0 0;
      }
      .corner.bl {
        bottom: 16px;
        left: 16px;
        border-right: 0;
        border-top: 0;
        border-radius: 0 0 0 8px;
      }
      .corner.br {
        bottom: 16px;
        right: 16px;
        border-left: 0;
        border-top: 0;
        border-radius: 0 0 8px 0;
      }
      .qr-host {
        position: relative;
        width: 56%;
        aspect-ratio: 1;
        background: #fff;
        border-radius: 12px;
        padding: 9px;
        box-shadow: 0 10px 30px -10px rgba(0, 0, 0, 0.5);
      }
      .scanline {
        position: absolute;
        left: 16px;
        right: 16px;
        height: 3px;
        border-radius: 3px;
        background: linear-gradient(90deg, transparent, var(--accent-400), transparent);
        box-shadow: 0 0 16px 3px color-mix(in srgb, var(--accent-400), transparent 30%);
        top: 16px;
        animation: scan 1.9s ease-in-out infinite;
      }
      @keyframes scan {
        0% {
          top: 18px;
        }
        50% {
          top: calc(100% - 20px);
        }
        100% {
          top: 18px;
        }
      }

      /* success overlay */
      .success {
        position: absolute;
        inset: 0;
        background: var(--accent-500);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 14px;
        color: var(--accent-contrast);
        opacity: 0;
        transform: scale(0.96);
        pointer-events: none;
        transition:
          opacity 0.3s,
          transform 0.3s;
      }
      .success.show {
        opacity: 1;
        transform: scale(1);
      }
      .success .check {
        width: 76px;
        height: 76px;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.18);
        display: grid;
        place-items: center;
      }
      .success .check i {
        font-size: 40px;
      }
      .success .nm {
        font-weight: 700;
        font-size: 19px;
      }
      .success .ti {
        font-size: 13px;
        opacity: 0.85;
      }

      .scr-foot {
        padding: 16px 20px;
        display: flex;
        flex-direction: column;
        gap: 9px;
      }
      .guest-row {
        display: flex;
        align-items: center;
        gap: 11px;
        padding: 10px 12px;
        border-radius: 12px;
        background: var(--bg-2);
        border: 1px solid var(--line);
        transition: 0.25s;
      }
      .guest-row.active {
        border-color: color-mix(in srgb, var(--accent-500), transparent 55%);
        background: var(--accent-50);
      }
      .guest-row .av {
        width: 32px;
        height: 32px;
        border-radius: 50%;
        display: grid;
        place-items: center;
        font-weight: 700;
        font-size: 13px;
        color: #fff;
        flex: none;
      }
      .guest-row .gi {
        flex: 1;
        min-width: 0;
      }
      .guest-row .gi .gn {
        font-size: 13px;
        font-weight: 600;
        color: var(--ink);
      }
      .guest-row .gi .gs {
        font-size: 11px;
        color: var(--ink-3);
      }
      .guest-row .badge {
        font-size: 11px;
        font-weight: 700;
        color: var(--accent-700);
        display: inline-flex;
        align-items: center;
        gap: 4px;
      }
      .guest-row .badge.pending {
        color: var(--ink-3);
      }

      /* floating confetti chips around phone */
      .chip {
        position: absolute;
        z-index: 2;
        display: inline-flex;
        align-items: center;
        gap: 7px;
        background: var(--bg);
        border: 1px solid var(--line);
        border-radius: 12px;
        padding: 9px 13px;
        box-shadow: var(--shadow-card);
        font-size: 13px;
        font-weight: 600;
        color: var(--ink);
      }
      .chip i {
        font-size: 15px;
      }
      .chip.c1 {
        top: 150px;
        left: -34px;
        color: var(--accent-700);
        animation: floaty 5s ease-in-out infinite;
      }
      .chip.c2 {
        bottom: 120px;
        right: -40px;
        animation: floaty 6s ease-in-out infinite 0.8s;
      }
      .chip.c3 {
        bottom: 30px;
        left: -16px;
        animation: floaty 5.5s ease-in-out infinite 0.4s;
      }
      @keyframes floaty {
        0%,
        100% {
          transform: translateY(0);
        }
        50% {
          transform: translateY(-9px);
        }
      }
      .confetti-dot {
        position: absolute;
        border-radius: 2px;
        opacity: 0.85;
        display: block;
      }

      /* ---------- section scaffolding ---------- */
      section.band {
        padding: 96px 0;
        position: relative;
      }
      .band.alt {
        background: var(--bg-2);
        border-top: 1px solid var(--line);
        border-bottom: 1px solid var(--line);
      }
      .sec-head {
        text-align: center;
        max-width: 620px;
        margin: 0 auto 56px;
      }
      .sec-tag {
        font-size: 13px;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--accent-600);
        margin-bottom: 14px;
      }
      .sec-head h2 {
        font-size: clamp(30px, 3.4vw, 42px);
        font-weight: 800;
        letter-spacing: -0.03em;
        margin: 0 0 14px;
        line-height: 1.05;
        text-wrap: balance;
      }
      .sec-head p {
        font-size: 18px;
        color: var(--ink-2);
        margin: 0;
        line-height: 1.55;
        text-wrap: pretty;
      }

      /* ---------- invite-method toggle ---------- */
      .method {
        display: grid;
        grid-template-columns: 0.9fr 1.1fr;
        gap: 48px;
        align-items: center;
      }
      .method .tabs {
        display: flex;
        flex-direction: column;
        gap: 12px;
      }
      .mtab {
        display: flex;
        gap: 15px;
        align-items: flex-start;
        text-align: left;
        cursor: pointer;
        background: var(--bg);
        border: 1px solid var(--line);
        border-radius: var(--radius);
        padding: 18px 20px;
        transition: 0.2s;
        width: 100%;
        font-family: inherit;
      }
      .mtab:hover {
        border-color: var(--p-slate-300);
      }
      .mtab.active {
        border-color: var(--accent-500);
        box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent-500), transparent 84%);
        background: var(--bg);
      }
      .mtab .mi {
        width: 44px;
        height: 44px;
        border-radius: 12px;
        flex: none;
        display: grid;
        place-items: center;
        font-size: 19px;
        background: var(--bg-2);
        color: var(--ink-2);
        transition: 0.2s;
      }
      .mtab.active .mi {
        background: var(--accent-500);
        color: var(--accent-contrast);
      }
      .mtab .mt {
        display: block;
        font-weight: 700;
        font-size: 16px;
        color: var(--ink);
        margin-bottom: 6px;
      }
      .mtab .md {
        display: block;
        font-size: 14px;
        color: var(--ink-3);
        line-height: 1.45;
      }

      .preview-stage {
        position: relative;
        min-height: 430px;
        display: flex;
        align-items: center;
        justify-content: center;
      }
      .preview-card {
        width: 100%;
        background: var(--bg);
        border: 1px solid var(--line);
        border-radius: var(--radius-lg);
        box-shadow: var(--shadow-card);
        overflow: hidden;
        position: absolute;
        opacity: 0;
        transform: translateY(14px) scale(0.98);
        pointer-events: none;
        transition:
          opacity 0.35s ease,
          transform 0.35s ease;
      }
      .preview-card.show {
        opacity: 1;
        transform: none;
        pointer-events: auto;
        position: relative;
      }

      /* email preview */
      .pv-email .hdr {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 16px 20px;
        border-bottom: 1px solid var(--line);
      }
      .pv-email .hdr .av {
        width: 40px;
        height: 40px;
        border-radius: 10px;
        background: var(--accent-500);
        color: var(--accent-contrast);
        display: grid;
        place-items: center;
        font-weight: 800;
      }
      .pv-email .hdr .who {
        font-weight: 700;
        font-size: 14px;
        color: var(--ink);
      }
      .pv-email .hdr .to {
        font-size: 12px;
        color: var(--ink-3);
      }
      .pv-email .body {
        padding: 24px 22px;
      }
      .pv-email .body .subj {
        font-size: 19px;
        font-weight: 800;
        letter-spacing: -0.02em;
        color: var(--ink);
        margin-bottom: 8px;
      }
      .pv-email .body .txt {
        font-size: 14px;
        color: var(--ink-2);
        line-height: 1.55;
        margin-bottom: 18px;
      }
      .pv-email .qr-block {
        display: flex;
        gap: 16px;
        align-items: center;
        padding: 16px;
        background: var(--bg-2);
        border: 1px solid var(--line);
        border-radius: 14px;
      }
      .pv-email .qr-block .qmeta .ql {
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: var(--ink-3);
      }
      .pv-email .qr-block .qmeta .qn {
        font-size: 15px;
        font-weight: 700;
        color: var(--ink);
        margin: 2px 0 3px;
      }
      .pv-email .qr-block .qmeta .qd {
        font-size: 12px;
        color: var(--ink-3);
      }

      /* link preview */
      .pv-link .urlbar {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 12px 16px;
        background: var(--bg-2);
        border-bottom: 1px solid var(--line);
      }
      .pv-link .urlbar .dots {
        display: flex;
        gap: 5px;
      }
      .pv-link .urlbar .dots span {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        background: var(--p-slate-300);
      }
      .pv-link .urlbar .addr {
        flex: 1;
        background: var(--bg);
        border: 1px solid var(--line);
        border-radius: 8px;
        padding: 7px 12px;
        font-size: 12px;
        color: var(--ink-3);
        font-family: var(--p-font-mono);
        display: flex;
        align-items: center;
        gap: 7px;
      }
      .pv-link .urlbar .addr i {
        color: var(--accent-600);
        font-size: 11px;
      }
      .pv-link .lp-body {
        padding: 26px 24px;
        text-align: center;
      }
      .pv-link .lp-body .ev {
        font-size: 12px;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--accent-600);
      }
      .pv-link .lp-body .evt {
        font-size: 22px;
        font-weight: 800;
        letter-spacing: -0.02em;
        color: var(--ink);
        margin: 8px 0 4px;
      }
      .pv-link .lp-body .evd {
        font-size: 13px;
        color: var(--ink-3);
        margin-bottom: 18px;
      }
      .pv-link .rsvp-row {
        display: flex;
        gap: 10px;
        justify-content: center;
      }

      /* card preview */
      .pv-card {
        background: var(--bg);
      }
      .pv-card .invite {
        position: relative;
        margin: 22px;
        border-radius: 18px;
        padding: 30px 26px 26px;
        background: linear-gradient(
          165deg,
          color-mix(in srgb, var(--accent-500), transparent 90%),
          var(--bg) 60%
        );
        border: 1px solid color-mix(in srgb, var(--accent-500), transparent 70%);
        overflow: hidden;
      }
      .pv-card .invite .deco {
        position: absolute;
        border-radius: 50%;
      }
      .pv-card .invite .deco.d1 {
        width: 120px;
        height: 120px;
        top: -40px;
        right: -30px;
        background: color-mix(in srgb, var(--accent-500), transparent 82%);
      }
      .pv-card .invite .deco.d2 {
        width: 64px;
        height: 64px;
        bottom: -20px;
        left: 40px;
        background: color-mix(in srgb, var(--accent-500), transparent 88%);
      }
      .pv-card .invite .ribbon {
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--accent-700);
        position: relative;
      }
      .pv-card .invite h3 {
        font-size: 26px;
        font-weight: 800;
        letter-spacing: -0.025em;
        color: var(--ink);
        margin: 10px 0 6px;
        position: relative;
        line-height: 1.05;
      }
      .pv-card .invite .meta {
        font-size: 13px;
        color: var(--ink-2);
        position: relative;
        display: flex;
        flex-direction: column;
        gap: 4px;
        margin-bottom: 18px;
      }
      .pv-card .invite .meta i {
        color: var(--accent-600);
        width: 16px;
      }
      .pv-card .invite .footer {
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        position: relative;
      }
      .pv-card .invite .footer .name {
        font-size: 13px;
      }
      .pv-card .invite .footer .name b {
        display: block;
        font-size: 15px;
        color: var(--ink);
      }
      .pv-card .invite .footer .name span {
        color: var(--ink-3);
      }

      /* ---------- feature cards ---------- */
      .fgrid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 22px;
      }
      .fcard {
        background: var(--bg);
        border: 1px solid var(--line);
        border-radius: var(--radius-lg);
        padding: 30px 28px;
        transition:
          transform 0.25s,
          box-shadow 0.25s,
          border-color 0.25s;
      }
      .fcard:hover {
        transform: translateY(-4px);
        box-shadow: var(--shadow-card);
        border-color: color-mix(in srgb, var(--accent-500), transparent 65%);
      }
      .fcard .ficon {
        width: 52px;
        height: 52px;
        border-radius: 14px;
        display: grid;
        place-items: center;
        font-size: 23px;
        background: var(--accent-50);
        color: var(--accent-600);
        margin-bottom: 22px;
      }
      .fcard h3 {
        font-size: 20px;
        font-weight: 700;
        letter-spacing: -0.02em;
        margin: 0 0 10px;
        color: var(--ink);
      }
      .fcard p {
        font-size: 15px;
        line-height: 1.55;
        color: var(--ink-2);
        margin: 0;
      }

      /* ---------- how it works ---------- */
      .steps {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 26px;
        position: relative;
      }
      .steps::before {
        content: '';
        position: absolute;
        top: 26px;
        left: 8%;
        right: 8%;
        height: 2px;
        background: repeating-linear-gradient(90deg, var(--line) 0 8px, transparent 8px 16px);
        z-index: 0;
      }
      .step {
        position: relative;
        z-index: 1;
      }
      .step .num {
        position: relative;
        width: 56px;
        height: 56px;
        border-radius: 16px;
        background: var(--accent-500);
        color: var(--accent-contrast);
        display: grid;
        place-items: center;
        font-size: 23px;
        font-weight: 800;
        margin-bottom: 20px;
        box-shadow: 0 10px 22px -10px color-mix(in srgb, var(--accent-500), transparent 40%);
        border: 4px solid var(--bg);
      }
      .band.alt .step .num {
        border-color: var(--bg-2);
      }
      .step .num .num-tag {
        position: absolute;
        top: -9px;
        right: -9px;
        width: 24px;
        height: 24px;
        border-radius: 50%;
        background: var(--ink);
        color: #fff;
        font-size: 12px;
        font-weight: 700;
        display: grid;
        place-items: center;
        border: 3px solid var(--bg);
      }
      .band.alt .step .num .num-tag {
        border-color: var(--bg-2);
      }
      .step h4 {
        font-size: 18px;
        font-weight: 700;
        letter-spacing: -0.02em;
        margin: 0 0 10px;
        color: var(--ink);
      }
      .step p {
        font-size: 14px;
        line-height: 1.5;
        color: var(--ink-2);
        margin: 0;
      }

      /* ---------- stats ---------- */
      .stats {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 24px;
      }
      .statc {
        text-align: center;
        padding: 8px;
      }
      .statc .sicon {
        width: 56px;
        height: 56px;
        border-radius: 16px;
        display: grid;
        place-items: center;
        margin: 0 auto 18px;
        font-size: 24px;
        background: var(--accent-50);
        color: var(--accent-600);
        border: 1px solid color-mix(in srgb, var(--accent-500), transparent 80%);
      }
      .statc .v {
        font-size: clamp(34px, 4vw, 50px);
        font-weight: 800;
        letter-spacing: -0.03em;
        color: var(--ink);
        line-height: 1;
      }
      .statc .v .accent {
        color: var(--accent-500);
      }
      .statc .l {
        font-size: 15px;
        color: var(--ink-2);
        margin-top: 10px;
      }

      /* ---------- final CTA ---------- */
      .cta-band {
        position: relative;
      }
      .cta-box {
        position: relative;
        overflow: hidden;
        border-radius: 28px;
        padding: 64px 40px;
        text-align: center;
        background: linear-gradient(150deg, var(--accent-600), var(--accent-500));
        box-shadow: var(--shadow-float);
      }
      .cta-box .cta-glow {
        position: absolute;
        width: 420px;
        height: 420px;
        border-radius: 50%;
        background: rgba(255, 255, 255, 0.14);
        top: -200px;
        right: -120px;
      }
      .cta-box .cta-glow.g2 {
        left: -140px;
        right: auto;
        top: auto;
        bottom: -220px;
        width: 380px;
        height: 380px;
      }
      .cta-box h2 {
        position: relative;
        color: #fff;
        font-size: clamp(30px, 3.6vw, 46px);
        font-weight: 800;
        letter-spacing: -0.03em;
        margin: 0 0 14px;
        line-height: 1.05;
        text-wrap: balance;
      }
      .cta-box p {
        position: relative;
        color: rgba(255, 255, 255, 0.9);
        font-size: 18px;
        margin: 0 0 30px;
      }
      .cta-box .btn-primary {
        background: #fff;
        color: var(--accent-700);
        border-color: #fff;
        box-shadow: 0 16px 30px -12px rgba(0, 0, 0, 0.3);
      }
      .cta-box .btn-primary:hover {
        background: #fff;
        transform: translateY(-2px);
        color: var(--accent-700);
      }

      /* ---------- footer ---------- */
      footer.foot {
        padding: 44px 0;
        border-top: 1px solid var(--line);
      }
      footer.foot .inner {
        max-width: var(--maxw);
        margin: 0 auto;
        padding: 0 28px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 20px;
        flex-wrap: wrap;
      }
      footer.foot .copy {
        font-size: 14px;
        color: var(--ink-3);
      }
      footer.foot .flinks {
        display: flex;
        gap: 22px;
      }
      footer.foot .flinks a {
        font-size: 14px;
        color: var(--ink-2);
        text-decoration: none;
      }
      footer.foot .flinks a:hover {
        color: var(--ink);
      }

      /* ---------- scroll reveal ---------- */
      .reveal {
        opacity: 0;
        transform: translateY(22px);
        transition:
          opacity 0.6s cubic-bezier(0.22, 1, 0.36, 1),
          transform 0.6s cubic-bezier(0.22, 1, 0.36, 1);
      }
      .reveal.in {
        opacity: 1;
        transform: none;
      }
      .reveal.d1 {
        transition-delay: 0.08s;
      }
      .reveal.d2 {
        transition-delay: 0.16s;
      }
      .reveal.d3 {
        transition-delay: 0.24s;
      }
      .reveal.d4 {
        transition-delay: 0.32s;
      }
      @media (prefers-reduced-motion: reduce) {
        .reveal {
          opacity: 1;
          transform: none;
          transition: none;
        }
        .scanline,
        .chip,
        .blink {
          animation: none !important;
        }
      }

      /* ---------- responsive ---------- */
      @media (max-width: 920px) {
        .hero .wrap {
          grid-template-columns: 1fr;
          text-align: center;
          justify-items: center;
          gap: 44px;
        }
        .lede {
          margin-left: auto;
          margin-right: auto;
        }
        .hero-cta,
        .hero-note {
          justify-content: center;
        }
        .method {
          grid-template-columns: 1fr;
          gap: 30px;
        }
        .fgrid {
          grid-template-columns: 1fr;
        }
        .steps {
          grid-template-columns: repeat(2, 1fr);
          gap: 36px 26px;
        }
        .steps::before {
          display: none;
        }
        .stats {
          grid-template-columns: 1fr;
          gap: 30px;
        }
        .nav .navlink.hide-sm {
          display: none;
        }
      }
      @media (max-width: 540px) {
        .steps {
          grid-template-columns: 1fr;
        }
        .hero {
          padding: 56px 0 50px;
        }
        section.band {
          padding: 70px 0;
        }
      }
    </style>
    {{--
      Shared brand tokens (same file the app uses) — loaded last so it
      drives the brand colour & fonts above. Edit inertia/css/brand_tokens.css
      to re-theme the marketing site and the app together.
    --}}
    @vite(['inertia/css/brand_tokens.css'])
  </head>
  <body>
    <nav class="nav" id="nav">
      <div class="inner">
        <a class="brand" href="#top">
          <span class="mark"><i class="pi pi-ticket"></i></span>
          Guest Invite
        </a>
        <a class="navlink hide-sm" href="#how">How it works</a>
        <a class="navlink hide-sm" href="#invite">Invitations</a>
        <div class="spacer"></div>
        <a class="navlink" href="/login">Login</a>
        <a class="btn btn-primary btn-sm" href="/signup">Get started</a>
      </div>
    </nav>

    <header class="hero" id="top">
      <div class="glow"></div>
      <div class="wrap">
        <div class="hero-copy">
          <span class="eyebrow reveal">
            <span class="dot"></span>
            QR invitations &amp; guest check-in
          </span>
          <h1 class="title reveal d1">
            
            
            
            
            
            Invite guests.





            <br />
            <span class="accent">Scan a QR.</span>
            
            
            
            
            
             Done.





          </h1>
          <p class="lede reveal d2">
            Create your event, build a guest list, and send invitations by email, shareable link, or printable card. Every invite carries a unique QR code for instant check-in at the door.
          </p>
          <div class="hero-cta reveal d3">
            <a class="btn btn-primary btn-lg" href="/signup">
              Create your event — free
              <i class="pi pi-arrow-right"></i>
            </a>
            <a class="btn btn-ghost btn-lg" href="/login">Login</a>
          </div>
          <div class="hero-note reveal d4">
            <i class="pi pi-check-circle"></i>
            No app for guests · Free to start · Set up in 2 minutes
          </div>
        </div>
        <div class="hero-visual reveal d2">
          <div class="stage" id="phone-stage">
            <span class="chip c1"><i class="pi pi-check-circle"></i> Checked in</span>
            <span class="chip c2"><i class="pi pi-qrcode"></i> Unique QR</span>
            <span class="chip c3"><i class="pi pi-bolt"></i> Instant</span>
            <i
              class="confetti-dot"
              style="width:10px;height:10px;top:24px;right:18px;background:#10b981;transform:rotate(20deg)"
            ></i>
            <i
              class="confetti-dot"
              style="width:8px;height:8px;top:120px;left:-6px;background:#f59e0b"
            ></i>
            <i
              class="confetti-dot"
              style="width:12px;height:12px;bottom:140px;right:-8px;background:#8b5cf6;transform:rotate(35deg)"
            ></i>
            <i
              class="confetti-dot"
              style="width:7px;height:7px;bottom:60px;left:30px;background:#0ea5e9"
            ></i>

            <div class="phone">
              <div class="notch"></div>
              <div class="screen">
                <div class="scr-top">
                  <div class="t">Door check-in</div>
                  <div class="live"><span class="blink"></span> Live</div>
                </div>

                <div class="viewfinder scan" id="viewfinder">
                  <div class="vignette"></div>
                  <div class="corner tl"></div>
                  <div class="corner tr"></div>
                  <div class="corner bl"></div>
                  <div class="corner br"></div>
                  <div class="qr-host" id="hero-qr"></div>
                  <div class="scanline" id="scanline"></div>
                  <div class="success" id="success">
                    <div class="check"><i class="pi pi-check"></i></div>
                    <div class="nm" id="success-nm"></div>
                    <div class="ti" id="success-ti"></div>
                  </div>
                </div>

                <div class="scr-foot">
                  <div class="guest-row active">
                    <div class="av" id="g0-av"></div>
                    <div class="gi">
                      <div class="gn" id="g0-nm"></div>
                      <div class="gs" id="g0-ti"></div>
                    </div>
                    <div class="badge" id="g0-badge"></div>
                  </div>
                  <div class="guest-row">
                    <div class="av" id="g1-av"></div>
                    <div class="gi">
                      <div class="gn" id="g1-nm"></div>
                      <div class="gs" id="g1-count"></div>
                    </div>
                    <div class="badge pending">Next</div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </header>

    <section class="band" id="features">
      <div class="wrap">
        <div class="sec-head">
          <div class="sec-tag reveal">Everything you need</div>
          <h2 class="reveal d1">One link from invite to front door</h2>
          <p class="reveal d2">
            Skip the spreadsheets and paper lists. Guest Invite handles invitations and check-in in a single flow.
          </p>
        </div>
        <div class="fgrid">
          <div class="fcard reveal d1">
            <div class="ficon"><i class="pi pi-send"></i></div>
            <h3>Invite your way</h3>
            <p>
              Email, a shareable link, or a printed card — each guest gets their own unique QR code.
            </p>
          </div>
          <div class="fcard reveal d2">
            <div class="ficon"><i class="pi pi-qrcode"></i></div>
            <h3>Scan to check in</h3>
            <p>
              Open the scanner at the door and check guests in with your phone camera in seconds.
            </p>
          </div>
          <div class="fcard reveal d3">
            <div class="ficon"><i class="pi pi-palette"></i></div>
            <h3>Design custom cards</h3>
            <p>Build beautiful invitation cards with a drag-and-drop editor — QR code included.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="band alt" id="invite">
      <div class="wrap">
        <div class="sec-head">
          <div class="sec-tag reveal">Invite your way</div>
          <h2 class="reveal d1">Pick how each guest gets their pass</h2>
          <p class="reveal d2">
            Same unique QR code, three ways to deliver it. Switch anytime — your guest list stays in sync.
          </p>
        </div>
        <div class="reveal d2">
          <div class="method">
            <div class="tabs">
              <button class="mtab active" data-method="email">
                <span class="mi"><i class="pi pi-envelope"></i></span>
                <span>
                  <span class="mt">Email</span><span class="md">
                    Send a branded invite straight to each guest's inbox.
                  </span>
                </span>
              </button>
              <button class="mtab" data-method="link">
                <span class="mi"><i class="pi pi-link"></i></span>
                <span>
                  <span class="mt">Shareable link</span><span class="md">
                    Drop one link in a group chat — everyone gets their own pass.
                  </span>
                </span>
              </button>
              <button class="mtab" data-method="card">
                <span class="mi"><i class="pi pi-id-card"></i></span>
                <span>
                  <span class="mt">Printable card</span><span class="md">
                    Design a card with the QR built in, ready to print or post.
                  </span>
                </span>
              </button>
            </div>

            <div class="preview-stage">
              <!--EMAIL-->
              <div class="preview-card pv-email show" data-preview="email">
                <div class="hdr">
                  <div class="av">E</div>
                  <div>
                    <div class="who">Guest Invite</div>
                    <div class="to">to maya@example.com</div>
                  </div>
                </div>
                <div class="body">
                  <div class="subj">You're invited — Aria's Rooftop Birthday</div>
                  <div class="txt">
                    Saturday, July 12 · 7:00 PM at The Skyline Loft. Show this code at the door — no app, no printout needed.
                  </div>
                  <div class="qr-block">
                    <div
                      style="width:78px;height:78px;flex:none;border-radius:10px;overflow:hidden;border:1px solid var(--line)"
                      data-qr="Maya-email"
                      data-qr-size="21"
                    ></div>
                    <div class="qmeta">
                      <div class="ql">Your pass</div>
                      <div class="qn">Maya Chen</div>
                      <div class="qd">Admits 1 · Table 4</div>
                    </div>
                  </div>
                  <div style="margin-top:18px">
                    <span class="btn btn-primary btn-sm">View invitation</span>
                  </div>
                </div>
              </div>
              <!--LINK-->
              <div class="preview-card pv-link" data-preview="link">
                <div class="urlbar">
                  <div class="dots"><span></span><span></span><span></span></div>
                  <div class="addr"><i class="pi pi-lock"></i> evt.to/aria-rooftop</div>
                </div>
                <div class="lp-body">
                  <div class="ev">You're invited</div>
                  <div class="evt">Aria's Rooftop Birthday</div>
                  <div class="evd">Sat, Jul 12 · 7:00 PM · The Skyline Loft</div>
                  <div
                    style="width:132px;height:132px;margin:0 auto 18px;border-radius:14px;overflow:hidden;border:1px solid var(--line);padding:8px;background:#fff"
                    data-qr="link-pass"
                    data-qr-size="23"
                  ></div>
                  <div class="rsvp-row">
                    <span class="btn btn-primary btn-sm">I'm coming</span>
                    <span class="btn btn-ghost btn-sm">Can't make it</span>
                  </div>
                </div>
              </div>
              <!--CARD-->
              <div class="preview-card pv-card" data-preview="card">
                <div class="invite">
                  <div class="deco d1"></div>
                  <div class="deco d2"></div>
                  <div class="ribbon">You're invited</div>
                  <h3>Aria's Rooftop Birthday</h3>
                  <div class="meta">
                    <span><i class="pi pi-calendar"></i> Saturday, July 12 · 7:00 PM</span>
                    <span><i class="pi pi-map-marker"></i> The Skyline Loft, Floor 14</span>
                  </div>
                  <div class="footer">
                    <div class="name"><b>Maya Chen</b><span>Admits 1 · Table 4</span></div>
                    <div
                      style="width:84px;height:84px;border-radius:12px;overflow:hidden;border:1px solid var(--line);padding:6px;background:#fff"
                      data-qr="card-pass"
                      data-qr-size="21"
                    ></div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="band" id="how">
      <div class="wrap">
        <div class="sec-head">
          <div class="sec-tag reveal">How it works</div>
          <h2 class="reveal d1">From idea to doorway in four steps</h2>
        </div>
        <div class="steps">
          <div class="step reveal d1">
            <div class="num"><i class="pi pi-calendar-plus"></i><span class="num-tag">1</span></div>
            <h4>Create an event</h4>
            <p>Add the date, place, and details.</p>
          </div>
          <div class="step reveal d2">
            <div class="num"><i class="pi pi-users"></i><span class="num-tag">2</span></div>
            <h4>Add guests</h4>
            <p>A name is enough — email and phone are optional.</p>
          </div>
          <div class="step reveal d3">
            <div class="num"><i class="pi pi-send"></i><span class="num-tag">3</span></div>
            <h4>Send invites</h4>
            <p>Email, link, or printable card, each with a QR code.</p>
          </div>
          <div class="step reveal d4">
            <div class="num"><i class="pi pi-clock"></i><span class="num-tag">4</span></div>
            <h4>Check them in</h4>
            <p>Scan the QR at the door. Instant verification.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="band alt">
      <div class="wrap">
        <div class="stats">
          <div class="statc reveal">
            <div class="sicon"><i class="pi pi-users"></i></div>
            <div class="v"><span class="accent">180K+</span></div>
            <div class="l">Guests checked in at the door</div>
          </div>
          <div class="statc reveal d1">
            <div class="sicon"><i class="pi pi-clock"></i></div>
            <div class="v">2 <span class="accent">min</span></div>
            <div class="l">Average time to set up an event</div>
          </div>
          <div class="statc reveal d2">
            <div class="sicon"><i class="pi pi-mobile"></i></div>
            <div class="v"><span class="accent">0</span></div>
            <div class="l">Apps your guests need to download</div>
          </div>
        </div>
      </div>
    </section>

    <section class="band cta-band">
      <div class="wrap">
        <div class="cta-box reveal">
          <div class="cta-glow"></div>
          <div class="cta-glow g2"></div>
          <h2>Ready to host your next event?</h2>
          <p>Create your first event free — no credit card, no app for your guests.</p>
          <a class="btn btn-primary btn-lg" href="/signup">
            Get started free
            <i class="pi pi-arrow-right"></i>
          </a>
        </div>
      </div>
    </section>

    <footer class="foot">
      <div class="inner">
        <div class="copy">© Guest Invite — QR invitations &amp; guest check-in</div>
        <div class="flinks">
          <a href="#">Privacy</a><a href="#">Terms</a><a href="#">Support</a>
        </div>
      </div>
    </footer>

    <script>
      (function () {
        'use strict';

        /* ---- Pseudo-QR: deterministic module grid with 3 finder patterns ---- */
        function fakeQR(seed, size, color) {
          size = size || 25;
          color = color || '#0f172a';
          var h = 2166136261;
          for (var i = 0; i < seed.length; i++) {
            h ^= seed.charCodeAt(i);
            h = Math.imul(h, 16777619);
          }
          var rng = function () {
            h ^= h << 13;
            h ^= h >>> 17;
            h ^= h << 5;
            return ((h >>> 0) % 1000) / 1000;
          };
          var n = size;
          var inFinder = function (r, c) {
            var zones = [
              [0, 0],
              [0, n - 7],
              [n - 7, 0],
            ];
            for (var z = 0; z < zones.length; z++) {
              var zr = zones[z][0],
                zc = zones[z][1];
              if (r >= zr && r < zr + 7 && c >= zc && c < zc + 7) return true;
            }
            return false;
          };
          var pad = (100 / size) * 1.4,
            span = 100 - pad * 2,
            m = span / n;
          var rects = '';
          for (var r = 0; r < n; r++)
            for (var c = 0; c < n; c++) {
              if (inFinder(r, c)) continue;
              if (rng() > 0.52) {
                rects +=
                  '<rect x="' +
                  (pad + c * m) +
                  '" y="' +
                  (pad + r * m) +
                  '" width="' +
                  m +
                  '" height="' +
                  m +
                  '" fill="' +
                  color +
                  '"/>';
              }
            }
          var finder = function (x, y) {
            return (
              '<g>' +
              '<rect x="' +
              (pad + x * m) +
              '" y="' +
              (pad + y * m) +
              '" width="' +
              m * 7 +
              '" height="' +
              m * 7 +
              '" rx="' +
              m +
              '" fill="' +
              color +
              '"/>' +
              '<rect x="' +
              (pad + (x + 1) * m) +
              '" y="' +
              (pad + (y + 1) * m) +
              '" width="' +
              m * 5 +
              '" height="' +
              m * 5 +
              '" rx="' +
              m * 0.7 +
              '" fill="#fff"/>' +
              '<rect x="' +
              (pad + (x + 2) * m) +
              '" y="' +
              (pad + (y + 2) * m) +
              '" width="' +
              m * 3 +
              '" height="' +
              m * 3 +
              '" rx="' +
              m * 0.5 +
              '" fill="' +
              color +
              '"/>' +
              '</g>'
            );
          };
          return (
            '<svg viewBox="0 0 100 100" style="width:100%;height:100%;display:block" shape-rendering="crispEdges">' +
            '<rect width="100" height="100" fill="#fff"/>' +
            rects +
            finder(0, 0) +
            finder(n - 7, 0) +
            finder(0, n - 7) +
            '</svg>'
          );
        }

        function initials(name) {
          return name
            .split(' ')
            .map(function (w) {
              return w[0];
            })
            .join('');
        }

        /* ---- static QR placeholders ---- */
        document.querySelectorAll('[data-qr]').forEach(function (el) {
          el.innerHTML = fakeQR(
            el.getAttribute('data-qr'),
            parseInt(el.getAttribute('data-qr-size'), 10) || 23,
          );
        });

        /* ---- hero phone scan demo ---- */
        var GUESTS = [
          { n: 'Maya Chen', s: 'VIP · Table 4', c: '#10b981' },
          { n: 'Diego Romero', s: 'Plus one', c: '#0ea5e9' },
          { n: 'Aria Okafor', s: 'Speaker', c: '#8b5cf6' },
          { n: 'Liam Patel', s: 'General admission', c: '#f59e0b' },
        ];
        var heroQr = document.getElementById('hero-qr');
        var viewfinder = document.getElementById('viewfinder');
        var scanline = document.getElementById('scanline');
        var successBox = document.getElementById('success');
        var successNm = document.getElementById('success-nm');
        var successTi = document.getElementById('success-ti');
        var g0av = document.getElementById('g0-av'),
          g0nm = document.getElementById('g0-nm'),
          g0ti = document.getElementById('g0-ti'),
          g0badge = document.getElementById('g0-badge');
        var g1av = document.getElementById('g1-av'),
          g1nm = document.getElementById('g1-nm'),
          g1count = document.getElementById('g1-count');

        var idx = 0,
          phase = 'scan',
          timer = null;
        var reduce =
          window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;

        function render() {
          var g = GUESTS[idx];
          var next = GUESTS[(idx + 1) % GUESTS.length];
          var checkedCount = 142 + idx;

          heroQr.innerHTML = fakeQR(g.n, 23);
          successNm.textContent = g.n;
          successTi.textContent = g.s;

          viewfinder.className = 'viewfinder ' + phase;
          scanline.style.display = phase === 'scan' ? '' : 'none';
          successBox.className = 'success' + (phase === 'success' ? ' show' : '');

          g0av.style.background = g.c;
          g0av.textContent = initials(g.n);
          g0nm.textContent = g.n;
          g0ti.textContent = g.s;
          if (phase === 'scan') {
            g0badge.className = 'badge pending';
            g0badge.innerHTML = '<span>Scanning…</span>';
          } else {
            g0badge.className = 'badge';
            g0badge.innerHTML = '<i class="pi pi-check-circle"></i> In';
          }

          g1av.style.background = next.c;
          g1av.textContent = initials(next.n);
          g1nm.textContent = next.n;
          g1count.textContent = checkedCount + ' of 180 checked in';
        }

        function tick() {
          if (phase === 'scan') {
            timer = setTimeout(function () {
              phase = 'success';
              render();
              tick();
            }, 2100);
          } else {
            timer = setTimeout(function () {
              idx = (idx + 1) % GUESTS.length;
              phase = 'scan';
              render();
              tick();
            }, 1700);
          }
        }

        render();
        if (!reduce) tick();

        /* ---- invite-method toggle ---- */
        var tabs = document.querySelectorAll('.mtab');
        var previews = document.querySelectorAll('.preview-card');
        tabs.forEach(function (tab) {
          tab.addEventListener('click', function () {
            var method = tab.getAttribute('data-method');
            tabs.forEach(function (t) {
              t.classList.toggle('active', t === tab);
            });
            previews.forEach(function (p) {
              p.classList.toggle('show', p.getAttribute('data-preview') === method);
            });
          });
        });

        /* ---- sticky nav border on scroll ---- */
        var nav = document.getElementById('nav');
        var onScroll = function () {
          nav.classList.toggle('scrolled', window.scrollY > 8);
        };
        window.addEventListener('scroll', onScroll, { passive: true });
        onScroll();

        /* ---- scroll reveal ---- */
        var reveals = document.querySelectorAll('.reveal');
        if (reduce || !('IntersectionObserver' in window)) {
          reveals.forEach(function (el) {
            el.classList.add('in');
          });
        } else {
          var io = new IntersectionObserver(
            function (entries) {
              entries.forEach(function (e) {
                if (e.isIntersecting) {
                  e.target.classList.add('in');
                  io.unobserve(e.target);
                }
              });
            },
            { rootMargin: '0px 0px -8% 0px', threshold: 0.08 },
          );
          reveals.forEach(function (el) {
            io.observe(el);
          });
        }
      })();
    </script>
  </body>
</html>
