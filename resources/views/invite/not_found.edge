<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="robots" content="noindex" />
  <title>Invitation not found</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: system-ui, -apple-system, Segoe UI, Roboto, sans-serif; background: #f3f4f6; color: #14110f; min-height: 100vh; display: grid; place-items: center; padding: 24px; }
    .box { text-align: center; max-width: 420px; }
    h1 { font-size: 64px; letter-spacing: -2px; }
    p { color: #6b7280; margin: 8px 0 24px; }
    a { display: inline-block; background: #111827; color: #fff; padding: 12px 22px; border-radius: 10px; font-weight: 600; text-decoration: none; }
  </style>
</head>
<body>
  <div class="box">
    <h1>404</h1>
    <p>This invitation link is invalid or has expired.</p>
    <a href="/">Go to homepage</a>
  </div>
</body>
</html>
