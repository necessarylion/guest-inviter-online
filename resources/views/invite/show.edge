<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />

  <title>{{ event.title }} — You're invited</title>
  <meta name="description" content="You're invited to {{ event.title }}. View the details and RSVP." />
  <meta name="robots" content="noindex" />

  <meta property="og:type" content="website" />
  <meta property="og:title" content="You're invited to {{ event.title }}" />
  <meta property="og:description" content="{{ event.when || 'View the invitation and RSVP.' }}" />
  <meta property="og:url" content="{{ inviteUrl }}" />
  @if(event.coverImageUrl)
    <meta property="og:image" content="{{ event.coverImageUrl }}" />
  @end
  <meta name="twitter:card" content="summary_large_image" />

  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: system-ui, -apple-system, Segoe UI, Roboto, sans-serif; background: #f3f4f6; color: #14110f; line-height: 1.5; padding: 24px; -webkit-font-smoothing: antialiased; }
    .card { max-width: 460px; margin: 24px auto; background: #fff; border: 1px solid #e5e7eb; border-radius: 18px; overflow: hidden; }
    .cover { height: 160px; background: #111827 center/cover no-repeat; }
    .body { padding: 28px; }
    .eyebrow { color: #6b7280; font-size: 14px; text-transform: uppercase; letter-spacing: 0.6px; }
    h1 { font-size: 28px; letter-spacing: -0.6px; margin: 6px 0 14px; }
    .meta { color: #4b5563; margin-bottom: 6px; }
    .desc { color: #4b5563; margin: 14px 0 0; }
    .qr { text-align: center; margin: 26px 0 8px; }
    .qr svg { width: 220px; height: 220px; border: 1px solid #e5e7eb; border-radius: 14px; padding: 10px; }
    .qr p { color: #6b7280; font-size: 14px; margin-top: 10px; }
    .divider { height: 1px; background: #e5e7eb; margin: 26px 0; }
    .rsvp h3 { font-size: 16px; margin-bottom: 12px; }
    .rsvp-row { display: flex; gap: 10px; }
    button { flex: 1; font: inherit; font-weight: 600; padding: 13px; border-radius: 10px; border: 1px solid #d1d5db; background: #fff; cursor: pointer; }
    button.primary { background: #111827; color: #fff; border-color: #111827; }
    .flash { padding: 12px 16px; border-radius: 10px; margin-bottom: 18px; font-weight: 500; font-size: 14px; }
    .flash-success { background: #00a63e1a; color: #00a63e; }
    .flash-error { background: #fb2c361a; color: #e7000b; }
    .status { text-align: center; font-weight: 600; padding: 12px; border-radius: 10px; background: #f9fafb; color: #374151; }
    .foot { text-align: center; color: #9ca3af; font-size: 13px; margin-top: 18px; }
  </style>
</head>
<body>
  <div class="card">
    @if(event.coverImageUrl)
      <div class="cover" style="background-image: url('{{ event.coverImageUrl }}')"></div>
    @end

    <div class="body">
      @if(flashMessages.has('success'))
        <div class="flash flash-success">{{ flashMessages.get('success') }}</div>
      @end
      @if(flashMessages.has('error'))
        <div class="flash flash-error">{{ flashMessages.get('error') }}</div>
      @end

      <div class="eyebrow">You're invited{{ guest.name ? ', ' + guest.name : '' }}</div>
      <h1>{{ event.title }}</h1>

      @if(event.when)
        <div class="meta">🗓️ {{ event.when }}</div>
      @end
      @if(event.location)
        <div class="meta">📍 {{ event.location }}{{ event.venueAddress ? ' — ' + event.venueAddress : '' }}</div>
      @end
      @if(event.description)
        <p class="desc">{{ event.description }}</p>
      @end

      <div class="qr">
        {{{ qrSvg }}}
        <p>Show this QR code at the entrance</p>
      </div>

      <div class="divider"></div>

      @if(event.allowPublicRsvp)
        <div class="rsvp">
          <h3>Will you attend?</h3>
          @if(guest.rsvpStatus === 'confirmed')
            <div class="status">✓ You're confirmed</div>
          @elseif(guest.rsvpStatus === 'declined')
            <div class="status">You've declined</div>
          @end
          <form method="POST" action="/i/{{ token }}/rsvp">
            @if(csrfField)
              {{{ csrfField() }}}
            @end
            <div class="rsvp-row" style="margin-top: 12px">
              <button type="submit" name="rsvpStatus" value="confirmed" class="primary">I'll be there</button>
              <button type="submit" name="rsvpStatus" value="declined">Can't make it</button>
            </div>
          </form>
        </div>
      @end

      <div class="foot">Powered by Event Inviter</div>
    </div>
  </div>
</body>
</html>
